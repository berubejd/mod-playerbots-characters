{
    // OpenAI-compatible /chat/completions endpoint.
    // The module appends /chat/completions to baseUrl automatically.
    "apiType": "openai",

    // Base URL of the endpoint. No trailing slash.
    "baseUrl": "https://api.openai.com/v1",

    // Bearer token sent in the Authorization header.
    // Leave empty for unauthenticated local endpoints (LM Studio, etc.).
    "apiKey": "",

    // HTTP request timeout in seconds. Keep low — events are processed
    // sequentially, so a slow/unreachable API stalls the whole queue.
    "requestTimeoutSec": 30,

    // Model identifier.
    "model": "gpt-5.4-mini",

    // Extra parameters merged into every request body's root.
    "requestParameters": {
        "reasoning": {"effort": "none"},
        // "temperature": 1.0
        // "frequency_penalty": 0.5,
        // "presence_penalty": 0.2,
        // "top_p": 0.95
    }
}

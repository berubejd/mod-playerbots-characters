[worldserver]

#########################################
# mod-playerbots-characters configuration
#########################################

# --------------------------------------------
# CORE MODULE TOGGLES & DEBUGGING
# --------------------------------------------

# PBC.Enable
#     Description: Enable or disable the module.
#     Default:     1 (true)
PBC.Enable = 1

# PBC.DebugEnabled
#     Description: Enables extra logging for debugging purposes.
#                  When set to 1 (true), detailed debug information will be logged by the module.
#                  When set to 0 (false), only standard logging is used.
#     Default:     0 (false)
PBC.DebugEnabled = 0

# PBC.DebugShowFullRequest
#     Description: When enabled (1), logs the request body and response body
#                  for every LLM API call.  Only active when PBC.DebugEnabled is also enabled.
#                  Long payloads (>1000 symbols) are truncated to first 100 + " ... " + last 900 symbols.
#                  When disabled (0), only standard logging is used.
#     Default:     0 (false)
PBC.DebugShowFullRequest = 0

# PBC.DisplayNarratorEvents
#     Description: When enabled (1), real players in the group will receive a system
#                  message showing the narrator event text when one of the defined events fire.
#                  This happens before characters process the event, regardless of whether
#                  any character rolls to respond.
#                  Additionally, all *text* blocks in a character's LLM reply are extracted
#                  and posted as separate narrator system messages, with the remaining text
#                  posted as regular chat. For example, the reply "*looks around* Hello!
#                  *waves* Goodbye!" is posted as four messages: two narrator system
#                  messages (*looks around*, *waves*) and two regular chat messages
#                  (Hello!, Goodbye!).
#     Default:     1 (true)
PBC.DisplayNarratorEvents = 1


# --------------------------------------------
# API CONNECTION
# --------------------------------------------

# PBC.APIType
#     Description: The type of LLM API to use.
#                  "openai"     — OpenAI-compatible /chat/completions endpoint (default).
#                                 The module appends /chat/completions to PBC.BaseUrl.
#                  "anthropic"  — Anthropic Messages API /messages endpoint.
#                                 The module appends /messages to PBC.BaseUrl.
#                                 Uses x-api-key header and anthropic-version header.
#     Default:     openai
PBC.APIType = openai

# PBC.BaseUrl
#     Description: The base URL of the LLM API.
#                  When PBC.APIType = openai:     the module appends /chat/completions to this URL.
#                  When PBC.APIType = anthropic:  the module appends /messages to this URL.
#                  REQUIRED. The module will be disabled if missing.
#     Default:     (empty)
PBC.BaseUrl =

# PBC.ApiKey
#     Description: Bearer token sent in the Authorization header.
#                  Leave blank if your endpoint does not require authentication
#                  (e.g. a local Ollama-compatible or LM Studio instance).
#     Default:     (empty)
PBC.ApiKey =

# PBC.RequestTimeoutSec
#     Description: HTTP request timeout in seconds.
#                  Keep low — if the API is unreachable you don't want to block a thread for long.
#     Default:     30
PBC.RequestTimeoutSec = 30


# --------------------------------------------
# MODEL PARAMETERS
# --------------------------------------------

# PBC.Model
#     Description: The model identifier to be used in the API request.
#                  REQUIRED. The module will be disabled if missing.
#     Default:     (empty)
PBC.Model =

# PBC.MaxResponseLength
#     Description: Maximum number of tokens for the model to generate.
#                  0 = unlimited.
#     Default:     120
PBC.MaxResponseLength = 120

# PBC.Temperature
#     Description: Controls the "creativity" or randomness of the model's output.
#                  Check model description to determine correct value.
#     Example:     PBC.Temperature = 0.6
#     Default:     1.0
PBC.Temperature = 1.0

# PBC.ModelExtraParameters
#     Description: Raw JSON fragment appended to every LLM request body.
#                  Spliced into the JSON object before the closing '}'.
#                  Use single quotes instead of double quotes — they are
#                  automatically replaced with double quotes at runtime.
#                  Leave empty for no extra parameters.
#     Example (DeepSeek): 'frequency_penalty':0.5,'presence_penalty':0.2
#     Example (GLM):       'thinking':{'type':'disabled'}
#     Default:     (empty)
PBC.ModelExtraParameters =

# PBC.MaxCtx
#     Description: Maximum context length (in tokens) before condensation happens.
#                  REQUIRED (must be > 0). The module will be disabled if missing.
#                  Recommended to keep it at around 25% of the total model max context.
#     Example:     PBC.MaxCtx = 32768
#     Default:     0
PBC.MaxCtx =

# PBC.CondensationPreservedLines
#     Description: Number of history lines kept after condensation.
#                  After the LLM summarises the history into a card addition, the in-memory
#                  and database history is trimmed to this many most-recent lines.
#                  Increase to preserve more recent context after each condensation.
#     Default:     50
PBC.CondensationPreservedLines = 50


# --------------------------------------------
# CHARACTER SETTINGS
# --------------------------------------------

# PBC.CharacterCardsPath
#     Description: Path to the directory containing character cards.
#                  This should be a relative path from the server's working directory.
#                  The module will load all .card.txt files from this directory and
#                  apply them to the needed characters.
#     Default:     ../../../modules/mod-playerbots-characters/characters
PBC.CharacterCardsPath = ../../../modules/mod-playerbots-characters/characters

# PBC.DefaultCharacterDescription
#     Description: Character description used when there is no associated character card.
#                  REQUIRED. The module will be disabled if missing.
PBC.DefaultCharacterDescription = "You are a {char_gender} {char_race} {char_class} named {char_name}. You are grounded in the world around you, you speak with a casual but authentic tone."

# PBC.CharacterContext
#     Description: Current context description appended to every prompt, always sent last.
#                  REQUIRED. The module will be disabled if missing.
PBC.CharacterContext = "You are {char_name}, a {char_gender} {char_race} {char_class}.\n{scene}\n{combat_status}\n{equipment}\n{char_group}\n{char_los}"


# --------------------------------------------
# PROMPTS
# --------------------------------------------

# PBC.SystemPrompt
#     Description: System prompt content, crucial for defining what the model should do.
#                  REQUIRED. The module will be disabled if missing.
PBC.SystemPrompt = "You are a character living in the world of Azeroth during the war against the Lich King. You have no awareness of being in a game, no knowledge of the internet, game patches, developers, or anything outside this world. You speak and think as a real inhabitant of Azeroth — a warrior, mage, rogue, or whatever your class dictates. You know the lore, the factions, the dangers, and the people of this world. You never break character. You never reference game mechanics as mechanics. You never mention World of Warcraft, Blizzard, expansions, patches, or player concepts. Respond only as your character would.\n\nYou will be presented with a description of your character, history and current context description. Your task is to respond as your character based on chat history, current context and the event that just happened. No commentary, no meta-talk, no prefix, no markdown — just a brief reply in one single line of plain text. Keep the reply reasonably short, since it's needed for a chat.\n\nFor example:\n*smiling* Hello, how are you?\n\nOr just:\nHello, how are you?\n\nWhen reacting to an event:\n*grins* That was quite the fight!"

# PBC.UserPrompt
#     Description: User prompt structure sent with every reply request.
#                  REQUIRED. The module will be disabled if missing.
PBC.UserPrompt = "[CHARACTER DESCRIPTION]\n{character_card}\n\n[HISTORY]\n{chat_history}\n\n[RELATIONSHIPS]\n{relationships}\n\n[CURRENT CONTEXT]\n{context}\n\n[CURRENT EVENT]\n{event}"

# PBC.CondensationSystemPrompt
#     Description: System prompt used when total chat history reaches PBC.MaxCtx
#                  to summarise previous events and expand the character description.
#                  REQUIRED. The module will be disabled if missing.
PBC.CondensationSystemPrompt = "Summarize the HISTORY so the CHARACTER DESCRIPTION could be expanded. Only output what should be added to the character description — no additional comments, no meta talk, just plain text. Be brief, but catch important things, follow the original description style. Individual events such as location visiting or items retrieval might not be as important, unless they lead to something in particular. In general focus on character development and what happened to the character. Write the summary in second person (using \"you/your\"), as it will be presented to the character as context. No commentary, no meta-talk, no prefix — just the summarization in one single line of plain text."

# PBC.CondensationUserPrompt
#     Description: User prompt used when total chat history reaches PBC.MaxCtx
#                  to summarise previous events and expand the character description.
#                  REQUIRED. The module will be disabled if missing.
PBC.CondensationUserPrompt = "[CHARACTER DESCRIPTION]\n{character_card}\n\n[HISTORY]\n{chat_history}"

# PBC.QuestTakenSystemPrompt
#     Description: System prompt used for the preliminary LLM call that summarises a
#                  newly accepted quest into a single narrative line. The result is then
#                  used as the [CURRENT EVENT] for each character's normal reply prompt.
#                  REQUIRED. The module will be disabled if missing.
PBC.QuestTakenSystemPrompt = "The party has accepted a new quest. Create a short description of it for a history log, phrasing it naturally based on how the quest was obtained. The quest source type is provided — adjust your wording accordingly:\n- If the source is a person: phrase it as receiving a task from someone (e.g. The party accepted a task from Gryan Stoutmantle to slay the Defias Brotherhood leader.).\n- If the source is an object (a world object like a signpost, bounty board, or shrine): phrase it as discovering or encountering something that offered a task (e.g. The party spotted a Wanted Poster offering a bounty to hunt down the Defias Brotherhood leader.).\n- If the source is an item (something carried, like a scroll, letter, or found artifact): phrase it as finding or examining something that revealed a task (e.g. The party found a Sealed Letter requesting the delivery of stolen goods to Stormwind.).\nDescribe everything as it would be known by inhabitants of Azeroth — use in-universe language and avoid game terminology. Output only the summary in one line of plain text — no comments, no formatting, no meta."

# PBC.QuestTakenUserPrompt
#     Description: User prompt for the quest-taken summary call.
#                  Supports placeholders: {quest_title}, {quest_giver}, {quest_giver_type},
#                  {quest_description}, {quest_log_description}, {quest_completion_log}.
#                  REQUIRED. The module will be disabled if missing.
PBC.QuestTakenUserPrompt = "[TITLE]\n{quest_title}\n\n[QUEST GIVER]\n{quest_giver}\n\n[QUEST GIVER TYPE]\n{quest_giver_type}\n\n[DESCRIPTION TEXT]\n{quest_description}\n\n[OBJECTIVES]\n{quest_log_description}\n{quest_completion_log}"

# PBC.QuestCompletedSystemPrompt
#     Description: System prompt used for the preliminary LLM call that summarises a
#                  completed quest into a single narrative line. The result is then used
#                  as the [CURRENT EVENT] for each character's normal reply prompt.
#                  REQUIRED. The module will be disabled if missing.
PBC.QuestCompletedSystemPrompt = "The party has completed a quest. Create a short description of it for a history log, phrasing it naturally based on how the quest was turned in. The quest ender type is provided — adjust your wording accordingly:\n- If the ender is a person: phrase it as reporting to someone (e.g. The party reported to Gryan Stoutmantle that they successfully slew the Defias Brotherhood leader.).\n- If the ender is an object (a world object like a shrine, monument, or delivery point): phrase it as delivering something to or interacting with that object (e.g. The party placed the recovered artifact at the Shrine of Remembrance, completing their task.).\nNote that the objectives may have been completed earlier — the party is now delivering the final report. Describe everything as it would be known by inhabitants of Azeroth — use in-universe language and avoid game terminology. Output only the summary in one line of plain text — no comments, no formatting, no meta."

# PBC.QuestCompletedUserPrompt
#     Description: User prompt for the quest-completed summary call.
#                  Supports placeholders: {quest_title}, {quest_giver}, {quest_giver_type},
#                  {quest_ender}, {quest_ender_type}, {quest_description},
#                  {quest_log_description}, {quest_completion_log}, {quest_reward_text}.
#                  REQUIRED. The module will be disabled if missing.
PBC.QuestCompletedUserPrompt = "[TITLE]\n{quest_title}\n\n[QUEST GIVER]\n{quest_giver}\n\n[QUEST GIVER TYPE]\n{quest_giver_type}\n\n[QUEST ENDER]\n{quest_ender}\n\n[QUEST ENDER TYPE]\n{quest_ender_type}\n\n[DESCRIPTION TEXT]\n{quest_description}\n\n[OBJECTIVES]\n{quest_log_description}\n{quest_completion_log}\n\n[COMPLETION TEXT]\n{quest_reward_text}"

# PBC.RelationshipUpdateSystemPrompt
#     Description: System prompt for the periodic relationship update LLM call.
#                  The model is asked to update a character's opinion of another
#                  character based on chat history.
#                  REQUIRED. The module will be disabled if missing.
PBC.RelationshipUpdateSystemPrompt = "You are an inhabitant of Azeroth. You will be presented with a description of your character, your character's history and your current relationship with another character. Your task is to update the relationship description with another character based on chat history. Write the relationship description in second person (using \"you/your\"), as it will be presented to the character as context. No commentary, no meta-talk, no prefix, no markdown — just the updated relationship description in one line of plain text. Be brief, but on point.\n\nFor example:\nWilliam seems to be a decent person and a competent warrior, he's been nice to you.\n\nIf the relationship info doesn't need updating or if there is just not enough history between your character and another one, simply return the same relationship description."

# PBC.RelationshipUpdateUserPrompt
#     Description: User prompt template for the relationship update LLM call.
#                  REQUIRED. The module will be disabled if missing.
PBC.RelationshipUpdateUserPrompt = "[CHARACTER DESCRIPTION]\n{character_card}\n\n[HISTORY]\n{chat_history}\n\n[RELATIONSHIP WITH {relationship_target}]\n{target_current_relationship}"

# PBC.RelationshipUpdateThreshold
#     Description: Number of new mentions of a character name in a character's history
#                  since the last relationship update before a new update is triggered.
#                  For example, if set to 100, a relationship update will be triggered
#                  every 100 new occurrences of the target's name in the character's history.
#                  Set to 0 to disable relationship updates entirely.
#     Default:     100
PBC.RelationshipUpdateThreshold = 100


# --------------------------------------------
# REPLY CHANCES
# --------------------------------------------

# PBC.ReplyChanceWhisper
#     Description: The percent chance (0-100) that a character would reply to whispers.
#     Default:     100
PBC.ReplyChanceWhisper = 100

# PBC.ReplyChanceMention
#     Description: The percent chance (0-100) that a character would reply when mentioned.
#     Default:     100
PBC.ReplyChanceMention = 100

# PBC.ReplyChanceMessage
#     Description: The initial percent chance (0-100) that a character would reply to a chat message.
#                  When there are no mentions, characters roll in random order. 
#                  The first character rolls at this chance. Each subsequent
#                  character rolls at a reduced chance (see RollPenaltyOnAnswer).
#     Default:     100
PBC.ReplyChanceMessage = 100

# PBC.RollPenaltyOnAnswer
#     Description: The percent penalty applied to the roll chance after a character successfully rolls
#                  to answer. For example, if ReplyChanceMessage is 100% and RollPenaltyOnAnswer
#                  is 45%, the first character rolls at 100%, the second at 55%, the third at 10%,
#                  and the fourth at 0% (no chance). If a character fails its roll, the next character
#                  rolls at the same chance without penalty.
#     Default:     45
PBC.RollPenaltyOnAnswer = 45

# PBC.ReplyChanceItem
#     Description: The percent chance (0-100) that a character would react when the party
#                  finds a rare (blue) or higher quality weapon or armor item.
#     Default:     5
PBC.ReplyChanceItem = 5

# PBC.ReplyChanceDuel
#     Description: The percent chance (0-100) that a character would react when a group member
#                  (or themselves) wins a duel.
#     Default:     5
PBC.ReplyChanceDuel = 5

# PBC.ReplyChanceLevelUp
#     Description: The percent chance (0-100) that a character would react when a group member
#                  (or themselves) levels up.
#     Default:     5
PBC.ReplyChanceLevelUp = 5

# PBC.ReplyChanceBossKill
#     Description: The percent chance (0-100) that each character in the party would react
#                  when the party slays a significant opponent: a dungeon or raid boss,
#                  a world boss, or a named elite creature.
#                  The event is always written to all character histories regardless of
#                  whether anyone rolls to respond.
#     Default:     35
PBC.ReplyChanceBossKill = 35

# PBC.ReplyChanceQuestCompleted
#     Description: The percent chance (0-100) that each character in the party would react
#                  when the party leader completes a quest. The LLM first generates a short
#                  summary of the quest, then each character independently rolls this chance to
#                  either use the summary as their current event (and reply) or write it
#                  directly into their history.
#     Default:     20
PBC.ReplyChanceQuestCompleted = 20

# PBC.ReplyChanceQuestTaken
#     Description: The percent chance (0-100) that each character in the party would react
#                  when the party leader accepts a new quest. The LLM first generates a
#                  short summary of the quest, then each character independently rolls this
#                  chance to either use the summary as their current event (and reply) or
#                  write it directly into their history.
#     Default:     10
PBC.ReplyChanceQuestTaken = 10


# --------------------------------------------
# HTTP SERVER
# --------------------------------------------

# PBC.HttpServerPort
#     Description: Port for the built-in HTTP/WS server.
#                  0 = disabled (default). Set to a positive port number to enable.
#                  The server provides both plain HTTP and WebSocket endpoints.
#                  When enabled, PBC.HttpServerPrivateKey is required.
#     Default:     0
PBC.HttpServerPort = 0

# PBC.HttpServerBind
#     Description: Bind address for the HTTP server.
#                  "127.0.0.1" = localhost only (default, recommended for security).
#                  "0.0.0.0"   = all interfaces (use with caution).
#     Default:     127.0.0.1
PBC.HttpServerBind = 127.0.0.1

# PBC.HttpServerTimeout
#     Description: Read/write timeout in seconds for the HTTP server.
#     Default:     15
PBC.HttpServerTimeout = 15

# PBC.HttpServerBaseUrl
#     Description: Base URL for the HTTP server, used for constructing
#                  external-facing URLs (e.g. for WebSocket connections).
#                  Should match the address and port that external clients
#                  will use to reach the server.
#     Default:     http://127.0.0.1:8501
PBC.HttpServerBaseUrl = http://127.0.0.1:8501

# PBC.HttpServerPrivateKey
#     Description: Secret key used for the authorization layer (token encryption).
#                  REQUIRED when PBC.HttpServerPort is not 0. The HTTP server will
#                  not start if this is empty.
#                  Must be a random string of at least 32 characters. You can generate
#                  one with: openssl rand -hex 32
#                  Changing this key invalidates all existing tokens.
#     Default:     (empty)
PBC.HttpServerPrivateKey =

# PBC.HttpServerFrontendPath
#     Description: Path to the directory containing frontend static files (HTML, JS, CSS).
#                  This should be a relative path from the server's working directory
#                  (typically env/dist/bin/). The HTTP server will serve these files
#                  for all non-API, non-WebSocket GET requests. GET / serves index.html.
#                  Leave empty to disable frontend serving.
#     Default:     ../../../modules/mod-playerbots-characters/frontend/dist
PBC.HttpServerFrontendPath = ../../../modules/mod-playerbots-characters/frontend/dist


# --------------------------------------------
# BLACKLIST
# --------------------------------------------

# PBC.Blacklist
#     Description: A comma-separated list of prefixes that should be ignored by the characters.
#                  If a message starts with any of these prefixes, the character will not respond.
#                  Additionally, this message won't be added to the future context.
#                  Note that `word ` and `word` are two different definitions.
PBC.Blacklist = t ,c ,items,autogear,talents,reset botAI,summon,release,revive,leave,attack,follow,flee,stay,runaway,grind,disperse,give leader,spells,cast ,quests,accept,drop,talk,reset,ss ,trainer,rti,rtsc,do ,ll ,e ,ue ,nc ,open,destroy,s ,b ,bank,gb ,u ,co ,ELVUI_VERSIONCHK,Asked,DPSMate_,LibGroupTalents,BLT,oRA3,Skada,HealBot,hbComms,questie,pfQuest,DBMv4-Ver,BWVQ3,add,remove,reset ai,report,state,help,log,stats,tank,offtank,healer,cc ,damage,boost,passive,defensive,aggressive,stay,guard,free,follow,assist,pet,stance,formation,rpg,emote,cheer,applaud,drink,eat,dance,attackers,reset instances,home,zone,who ,who,pos ,tele,grind,loot,quest,trainer,travel,teleport,homebind,unfollow,invite,uninvite,join,leave,leader,ready,release,save,update,reset talents,gear,trade,mail,ah ,ahscan,ahbid,ahbuy,ahsell,ahcancel,bag,repair,vendor,train,spells,reset spells,learn,unlearn,cast,uncast,use ,move,go ,look,stop,turn,face,wait,party,followleader,stayleader,moveleader,info,distance,debug,reset path,reset state,reset all,reset dungeon,reset raid,zone info,LHC40,RECOUNT,GTFO_v,Altoholic,DS_,DataStore
